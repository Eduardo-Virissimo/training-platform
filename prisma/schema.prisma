generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  INSTRUCTOR
}

model User {
  id            String         @id @default(uuid()) @db.VarChar(36)
  name          String
  email         String         @unique
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]

  avatarFileId String?    @unique @db.VarChar(36)
  avatarFile   FileUsage? @relation(fields: [avatarFileId], references: [id], onDelete: SetNull)

  trainings    UserTraining[]
  tracks       UserTrack[]
  quizAttempts QuizAttempt[]
  files        File[]
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  token     String   @unique @db.VarChar(500)
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model File {
  id        String     @id @default(uuid()) @db.VarChar(36)
  filename  String
  path      String
  mimetype  String
  key       String     @unique
  size      Int
  userId    String     @db.VarChar(36)
  uploader  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  fileUsage FileUsage?
}

model FileUsage {
  id        String        @id @default(uuid()) @db.VarChar(36)
  fileId    String        @unique @db.VarChar(36)
  usageType FileUsageType
  usageId   String        @db.VarChar(36)

  file  File   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  users User?
}

enum FileUsageType {
  TRAINING
  TRACK
  QUIZ
  AVATAR
}

model Training {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String
  description String?
  content     String  @db.LongText

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tracks        TrackTraining[]
  userTrainings UserTraining[]
}

model Track {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String
  description String?

  createdAt DateTime @default(now())

  trainings  TrackTraining[]
  userTracks UserTrack[]
  quizTracks QuizTrack[]
}

model TrackTraining {
  trackId    String @db.VarChar(36)
  trainingId String @db.VarChar(36)

  position Int

  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@id([trackId, trainingId])
}

model UserTraining {
  id          String    @id @default(uuid()) @db.VarChar(36)
  userId      String    @db.VarChar(36)
  trainingId  String    @db.VarChar(36)
  status      String
  startedAt   DateTime?
  completedAt DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingId])
}

enum UserTrackStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum UserTrackRole {
  STUDENT
  INSTRUCTOR
}

model UserTrack {
  id String @id @default(uuid()) @db.VarChar(36)

  userId  String        @db.VarChar(36)
  trackId String        @db.VarChar(36)
  role    UserTrackRole @default(STUDENT)

  status UserTrackStatus @default(NOT_STARTED)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model QuizTrack {
  trackId String @db.VarChar(36)
  quizId  String @db.VarChar(36)

  position Int

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  quiz  Quiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@id([trackId, quizId])
}

model Quiz {
  id          String  @id @default(uuid()) @db.VarChar(36)
  title       String
  description String?

  createdAt DateTime @default(now())

  quizTracks QuizTrack[]
  questions  Question[]
  attempts   QuizAttempt[]
}

model Question {
  id     String @id @default(uuid()) @db.VarChar(36)
  quizId String @db.VarChar(36)

  content String       @db.LongText
  type    QuestionType

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  options Option[]
  answers Answer[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  SINGLE_CHOICE
  TRUE_FALSE
}

model Option {
  id         String @id @default(uuid()) @db.VarChar(36)
  questionId String @db.VarChar(36)

  content   String
  isCorrect Boolean

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  Answer[]
}

model QuizAttempt {
  id String @id @default(uuid()) @db.VarChar(36)

  userId String @db.VarChar(36)
  quizId String @db.VarChar(36)

  score  Float
  passed Boolean

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  answers Answer[]
}

model Answer {
  id String @id @default(uuid()) @db.VarChar(36)

  attemptId  String @db.VarChar(36)
  questionId String @db.VarChar(36)
  optionId   String @db.VarChar(36)

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   Option      @relation(fields: [optionId], references: [id], onDelete: Cascade)
}
